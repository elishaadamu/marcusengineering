---
layout: none
---
{% assign search_items = "" | split: "" %}

{% for p in site.pages %}
  {% if p.title and p.url contains ".html" or p.url == "/" %}
    {% capture item %}
    {
      "title": {{ p.title | jsonify }},
      "url": {{ p.url | relative_url | jsonify }},
      "type": "Page",
      "content": {{ p.content | strip_html | strip_newlines | truncate: 160 | jsonify }}
    }
    {% endcapture %}
    {% assign search_items = search_items | push: item %}
  {% endif %}
{% endfor %}

{% assign authors = site.pages | where: "layout", "author" %}
{% for author in authors %}
  {% capture item %}
  {
    "title": {{ author.title | jsonify }},
    "url": {{ author.permalink | relative_url | jsonify }},
    "type": "Author",
    "content": {{ author.content | strip_html | strip_newlines | truncate: 160 | jsonify }}
  }
  {% endcapture %}
  {% assign search_items = search_items | push: item %}
{% endfor %}

{% for post in site.posts %}
  {% capture item %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "type": "Post",
    "date": "{{ post.date | date: '%B %d, %Y' }}",
    "content": {{ post.excerpt | strip_html | strip_newlines | truncate: 160 | jsonify }}
  }
  {% endcapture %}
  {% assign search_items = search_items | push: item %}
{% endfor %}

[
  {{ search_items | join: "," }}
]
